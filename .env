# ============================================================
# Required
# ============================================================
BOT_TOKEN=
DATABASE_URL=

# Secret used by Roblox/webhook requests. Send this as X-Secret-Key.
API_SECRET_KEY=change-this-secret

# ============================================================
# Department branding
# ============================================================
DEPARTMENT_NAME=Engineering and Technical Service
DEPARTMENT_ABBREVIATION=E&T
DEPARTMENT_COLOR=2F6F8F
DEPARTMENT_GROUP_URL=https://www.roblox.com/communities/515594004/SCPF-Engineering-and-Technical-Service#!/about
DEPARTMENT_DESCRIPTION=The Engineering and Technical Service Department (E&T) is responsible for the upkeep and maintenance of the facility. Whether it’s repairing a door or making changes to an SCP's containment zone, E&T is vital to ensuring smooth operations can persist within the facility.

# ============================================================
# Discord channels
# ============================================================
ACTIVITY_LOG_CHANNEL_ID=
COMMAND_LOG_CHANNEL_ID=
ROBLOX_AUDIT_LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=
WEEKLY_REPORT_CHANNEL_ID=

# ============================================================
# Discord roles
# If a manager-specific role is blank, MANAGEMENT_ROLE_ID or Administrator can still use it.
# ============================================================
MANAGEMENT_ROLE_ID=
RANK_MANAGER_ROLE_ID=
STRIKE_MANAGER_ROLE_ID=
ACTIVITY_MANAGER_ROLE_ID=
WELCOME_MANAGER_ROLE_ID=
DEPARTMENT_ROLE_ID=

# ============================================================
# Roblox group/rank service
# ============================================================
ROBLOX_GROUP_ID=515594004
ROBLOX_SERVICE_BASE=
ROBLOX_SERVICE_SECRET=

# ============================================================
# Activity settings
# ============================================================
WEEKLY_TIME_REQUIREMENT=120
AUTO_WEEKLY_REPORT=false
AUTO_WEEKLY_RESET=false
AUTO_REPORT_WEEKDAY_UTC=6
AUTO_REPORT_HOUR_UTC=0
AUTO_INACTIVITY_STRIKES=false

# ============================================================
# Strike settings
# ============================================================
DEFAULT_STRIKE_DURATION_DAYS=30
MAX_STRIKES=3

# ============================================================
# Welcome message
# Variables supported: {member}, {member_name}, {department}, {abbreviation}, {group_url}, {description}
# ============================================================
WELCOME_TITLE=Welcome to Engineering and Technical Service
WELCOME_MESSAGE=Welcome {member} to Engineering and Technical Service (E&T)! Please verify with `/verify`, review the department information, and stay active on-site.\n\n{description}\n\nGroup: {group_url}
