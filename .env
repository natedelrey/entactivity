# ============================================================
# Required
# ============================================================
BOT_TOKEN=
DATABASE_URL=

# Secret used by Roblox/webhook requests. Send this as X-Secret-Key.
API_SECRET_KEY=change-this-secret

# ============================================================
# Department branding
# ============================================================
DEPARTMENT_NAME=Ethics Committee
DEPARTMENT_ABBREVIATION=EC
DEPARTMENT_COLOR=2A3825
DEPARTMENT_GROUP_URL=https://www.roblox.com/communities/34438615/

# ============================================================
# Discord channels
# ============================================================
ACTIVITY_LOG_CHANNEL_ID=
COMMAND_LOG_CHANNEL_ID=
ROBLOX_AUDIT_LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=
WEEKLY_REPORT_CHANNEL_ID=

# ============================================================
# Discord roles
# If a manager-specific role is blank, MANAGEMENT_ROLE_ID or Administrator can still use it.
# ============================================================
MANAGEMENT_ROLE_ID=
RANK_MANAGER_ROLE_ID=
STRIKE_MANAGER_ROLE_ID=
ACTIVITY_MANAGER_ROLE_ID=
WELCOME_MANAGER_ROLE_ID=
DEPARTMENT_ROLE_ID=

# ============================================================
# Roblox group/rank service
# ============================================================
ROBLOX_GROUP_ID=34438615
ROBLOX_SERVICE_BASE=
ROBLOX_SERVICE_SECRET=

# ============================================================
# Activity settings
# ============================================================
WEEKLY_TIME_REQUIREMENT=120
AUTO_WEEKLY_REPORT=false
AUTO_WEEKLY_RESET=false
AUTO_REPORT_WEEKDAY_UTC=6
AUTO_REPORT_HOUR_UTC=0
AUTO_INACTIVITY_STRIKES=false

# ============================================================
# Strike settings
# ============================================================
DEFAULT_STRIKE_DURATION_DAYS=30
MAX_STRIKES=3

# ============================================================
# Welcome message
# Variables supported: {member}, {member_name}, {department}, {abbreviation}, {group_url}
# ============================================================
WELCOME_TITLE=Welcome to the Ethics Committee
WELCOME_MESSAGE=Welcome {member} to the Ethics Committee! Please verify with `/verify`, review the handbook, and stay active on-site.
